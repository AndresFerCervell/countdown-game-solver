PROJECT_NAME           = "Práctica final - Juego de Cifras y Letras"
PROJECT_BRIEF          = "Documentación del proyecto Cifras y Letras"
OUTPUT_DIRECTORY       = ./doc_doxygen
INPUT                  = ./include ./src ./doc
RECURSIVE              = YES
EXCLUDE_PATTERNS       = */cmake-build-debug/*
GENERATE_LATEX         = NO
IMAGE_PATH             = ./doc
EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = NO
EXTRACT_STATIC         = YES
HIDE_UNDOC_MEMBERS     = NO
OPTIMIZE_OUTPUT_FOR_C  = NO
OPTIMIZE_OUTPUT_JAVA   = NO
OPTIMIZE_FOR_FORTRAN   = NO
OPTIMIZE_OUTPUT_VHDL   = NO
HAVE_DOT               = YES
DOT_IMAGE_FORMAT       = svg
DOT_TRANSPARENT        = YES
INTERACTIVE_SVG        = YES
CALL_GRAPH             = YES
CALLER_GRAPH           = YES
CLASS_GRAPH            = YES
COLLABORATION_GRAPH    = YES
GENERATE_HTML          = YES
HTML_EXTRA_STYLESHEET  = ./doc/mi_estilo_moderno.css
HTML_OUTPUT            = html
HTML_COLORSTYLE        = LIGHT
HTML_DYNAMIC_SECTIONS  = YES
GENERATE_TREEVIEW      = YES
SORT_MEMBER_DOCS       = YES
SORT_BRIEF_DOCS        = YES
SORT_BY_SCOPE_NAME     = YES
SHOW_USED_FILES        = NO
SHOW_INCLUDE_FILES     = NO